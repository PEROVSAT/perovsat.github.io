---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>Copyright &copy; {year} PEROVSAT — Rhodes College</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rhodes-border);
    background: var(--rhodes-surface);
    color: var(--rhodes-text-muted);
    font-size: 0.875rem;
    text-align: center;
    padding: 1.5rem;
  }

  .site-footer p {
    margin: 0;
  }
</style>
